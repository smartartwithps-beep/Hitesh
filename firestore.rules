rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pillar 2: Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'quitDate', 'cigarettesPerDay', 'updatedAt']) &&
             data.keys().size() == 4 &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 100 &&
             data.quitDate is string && data.quitDate.size() <= 64 &&
             data.cigarettesPerDay is int && data.cigarettesPerDay >= 0 &&
             data.updatedAt == request.time;
    }

    match /users/{userId} {
      // Pillar 8: Secure List Queries
      allow list: if isSignedIn();
      
      // Pillar 3: Path Variable Hardening
      allow get: if isSignedIn() && isValidId(userId);
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming());
      
      allow update: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming()) && (
                        // Only allowed fields can change
                        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'quitDate', 'cigarettesPerDay', 'updatedAt'])
                      );
      
      allow delete: if false;
    }
  }
}
